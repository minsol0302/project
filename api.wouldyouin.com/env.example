# ─────────────────────────────────────────────
# WouldYouIn API - 환경변수 예시 파일
# 실제 값은 .env 에 복사해서 입력 (이 파일은 git에 커밋됨)
# ─────────────────────────────────────────────

# Neon DB (PostgreSQL)
# 형식: postgresql://유저명:비밀번호@호스트/DB명?sslmode=require
DATABASE_URL=postgresql://유저명:비밀번호@호스트/DB명?sslmode=require

# JWT 설정
JWT_SECRET=여기에-랜덤-시크릿키-입력
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# Gemini API (AI 기능 사용 시)
GEMINI_API_KEY=여기에-Gemini-API-KEY-입력

# CORS 허용 출처 (JSON 배열 형식)
CORS_ORIGINS=["http://localhost:3000","https://www.wouldyouin.com"]




